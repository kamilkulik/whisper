{
  "name": "wieczorny_szept",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --turbopack",
    "dev:local": "echo '🚀 Starting local development server...' && echo '📱 Your local API will be available at:' && ifconfig | grep 'inet ' | grep -v '127.0.0.1' | awk '{print \"   http://\" $2 \":3000\"}' | head -1 && echo '   http://localhost:3000' && echo '' && next dev --turbopack --hostname 0.0.0.0",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev --name init",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "stripe:webhook": "stripe listen --forward-to localhost:3000/api/payments/webhook"
  },
  "dependencies": {
    "@prisma/client": "^6.13.0",
    "@radix-ui/react-dialog": "^1.1.15",
    "@react-email/components": "^0.5.1",
    "@react-email/render": "1.2.1",
    "@stripe/stripe-js": "^7.8.0",
    "dompurify": "^3.2.6",
    "form-data": "^4.0.4",
    "jose": "^6.1.0",
    "next": "15.4.5",
    "prisma": "^6.13.0",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "resend": "^6.0.1",
    "server-only": "^0.0.1",
    "smsapi": "^2.1.1",
    "stripe": "^18.4.0",
    "uuid": "^11.1.0",
    "zod": "^4.0.16"
  },
  "devDependencies": {
    "@react-email/preview": "^0.0.13",
    "@types/dompurify": "^3.2.0",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "autoprefixer": "^10.4.14",
    "postcss": "^8.4.24",
    "tailwindcss": "^3.3.0",
    "typescript": "^5"
  }
}
