// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum SupportedLanguagesEnum {
  PL
  EN
  ES
  IT
}

enum SubscriptionType {
  TRIAL
  ONE_TIME
  MONTHLY
}

enum PaymentProvider {
  STRIPE
}

enum SubscriptionStatus {
  ACTIVE
  CANCEL_AT_PERIOD_END
  PENDING
  EXPIRED
  FAILED
  REFUNDED
  PAUSED
}

model Message {
  id        Int       @id @default(autoincrement())
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime? @updatedAt @map("updated_at")

  // Relation to users who used this message
  users User[]

  // Relation to translations
  translations MessageTranslation[]

  @@map("messages")
}

model MessageTranslation {
  id        Int     @id @default(autoincrement())
  messageId Int     @map("message_id")
  message   Message @relation(fields: [messageId], references: [id])

  language SupportedLanguagesEnum
  text     String
  length   Int // precomputed length of `text`

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime? @updatedAt @map("updated_at")

  @@unique([messageId, language]) // one translation per language
  @@map("message_translations")
}

model User {
  id                      Int                    @id @default(autoincrement())
  confirmationCode        Int?                   @map("confirmation_code")
  confirmationCodeExpires DateTime?              @map("confirmation_code_expires")
  phoneNumber             String                 @unique @map("phone_number")
  phoneNumberVerified     Boolean                @default(false) @map("phone_number_verified")
  email                   String                 @unique
  emailVerified           Boolean                @default(false) @map("email_verified")
  name                    String
  trialEnds               DateTime?              @map("trial_ends")
  premium                 Boolean                @default(false)
  lastUsedMessageId       Int?                   @map("last_used_message")
  messageLanguage         SupportedLanguagesEnum @map("message_language")
  sessionId               String?                @unique @map("session_id")
  createdAt               DateTime               @default(now()) @map("created_at")
  updatedAt               DateTime?              @updatedAt @map("updated_at")

  // Relation to the last used message
  lastUsedMessage Message?       @relation(fields: [lastUsedMessageId], references: [id])
  Subscription    Subscription[]

  @@map("users")
}

model Subscription {
  id              Int                @id @default(autoincrement())
  subscriptionId  String?            @map("subscription_id") // missing for trial subs
  paymentProvider PaymentProvider    @default(STRIPE)
  userId          Int                @map("user_id")
  user            User               @relation(fields: [userId], references: [id])
  type            SubscriptionType
  status          SubscriptionStatus
  dateCancelled   DateTime?          @map("date_cancelled")
  dateStarted     DateTime           @map("date_started")
  dateRefunded    DateTime?          @map("date_refunded")
  dateExpires     DateTime?          @map("date_expires")
  createdAt       DateTime           @default(now()) @map("created_at")
  updatedAt       DateTime?          @updatedAt @map("updated_at")

  @@map("subscriptions")
}

model KeyValue {
  id        Int       @id @default(autoincrement())
  key       String    @unique
  value     String
  expiresAt DateTime? @map("expires_at")
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime? @updatedAt @map("updated_at")

  @@map("key_values")
}

model WebhookEventLog {
  id        Int       @id @default(autoincrement())
  eventId   String    @unique @map("event_id")
  eventData Json      @map("event_data")
  eventType String    @map("event_type")
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime? @updatedAt @map("updated_at")

  @@map("webhook_event_log")
}
